{
  "name": "nlite",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "nlite": "./bin/nlite.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./link": {
      "types": "./dist/link.d.mts",
      "import": "./dist/link.mjs"
    },
    "./navigation": {
      "types": "./dist/navigation.d.mts",
      "import": "./dist/navigation.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.mts",
      "import": "./dist/runtime.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-rsc": "^0.5.23",
    "tinyglobby": "^0.2.16",
    "vite": "^8.0.8"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  }
}
